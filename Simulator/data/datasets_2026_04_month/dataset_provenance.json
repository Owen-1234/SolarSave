      "rows": 50
    }
  },
  "generation_method": {
    "default_reward_share": 0.2,
    "fdia_injection": {
      "attack_rate": 0.05,
      "attack_records": 1800,
      "rules": [
        "nighttime impossible reports use a positive reported output when P_max is near zero",
        "daylight FDIA reports multiply P_max by one of 0.42, 1.38, 1.55, or 1.82",
        "verification_status is initialized as rejected for injected FDIA records"
      ]
    },
    "nodes_per_city": 10,
    "random_seed": 20260511,
    "reserve_buffer_MW": 0.018,
    "script": "Simulator/data/generate_monthly_datasets.py"
  },
  "selected_ratio": {
    "liquidity_share": 0.8,
    "reward_share": 0.2,
